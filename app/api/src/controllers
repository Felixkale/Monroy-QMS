// ==================== CLIENTS CONTROLLER ====================
// File: apps/api/src/controllers/clients.controller.ts

import { Request, Response } from "express";
import * as clients from "../services/clients.service";

export async function listClients(_req: Request, res: Response) {
  const data = await clients.listClients();
  res.json({ ok: true, data });
}

export async function createClient(req: Request, res: Response) {
  const data = await clients.createClient(req.body);
  res.status(201).json({ ok: true, data });
}

export async function getClient(req: Request, res: Response) {
  const data = await clients.getClient(req.params.id);
  res.json({ ok: true, data });
}

export async function updateClient(req: Request, res: Response) {
  const data = await clients.updateClient(req.params.id, req.body);
  res.json({ ok: true, data });
}

export async function deleteClient(req: Request, res: Response) {
  await clients.deleteClient(req.params.id);
  res.json({ ok: true });
}

