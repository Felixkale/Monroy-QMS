// ==================== CLIENTS SERVICE ====================
// File: apps/api/src/services/clients.service.ts

import { supabaseService } from "../config/supabase";
import { HttpError } from "../utils/httpError";

export async function listClients() {
  const { data, error } = await supabaseService
    .from("clients")
    .select("*")
    .order("created_at", { ascending: false });

  if (error) throw new HttpError(400, error.message, error);
  return data ?? [];
}

export async function createClient(payload: any) {
  if (!payload?.company_name) throw new HttpError(400, "Company name is required");

  const { data, error } = await supabaseService
    .from("clients")
    .insert({
      company_name: payload.company_name,
      company_code: payload.company_code ?? null,
      contact_email: payload.contact_email ?? null,
      contact_phone: payload.contact_phone ?? null,
      status: payload.status ?? "active"
    })
    .select("*")
    .single();

  if (error) throw new HttpError(400, error.message, error);
  return data;
}

export async function getClient(id: string) {
  const { data, error } = await supabaseService
    .from("clients")
    .select("*, sites(*), assets(*)")
    .eq("id", id)
    .single();

  if (error) throw new HttpError(404, "Client not found");
  return data;
}

export async function updateClient(id: string, payload: any) {
  const { data, error } = await supabaseService
    .from("clients")
    .update({
      company_name: payload.company_name,
      company_code: payload.company_code,
      contact_email: payload.contact_email,
      contact_phone: payload.contact_phone,
      status: payload.status
    })
    .eq("id", id)
    .select("*")
    .single();

  if (error) throw new HttpError(400, error.message, error);
  return data;
}

export async function deleteClient(id: string) {
  const { error } = await supabaseService.from("clients").delete().eq("id", id);
  if (error) throw new HttpError(400, error.message, error);
}

