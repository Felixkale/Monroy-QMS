// ==================== ASSETS SERVICE ====================
// File: apps/api/src/services/assets.service.ts

export async function listAssets(clientId?: string, siteId?: string) {
  let query = supabaseService.from("assets").select("*");

  if (clientId) query = query.eq("client_id", clientId);
  if (siteId) query = query.eq("site_id", siteId);

  const { data, error } = await query.order("created_at", { ascending: false });

  if (error) throw new HttpError(400, error.message, error);
  return data ?? [];
}

export async function createAsset(payload: any) {
  if (!payload?.asset_name) throw new HttpError(400, "Asset name is required");

  const { data, error } = await supabaseService
    .from("assets")
    .insert({
      client_id: payload.client_id,
      site_id: payload.site_id,
      asset_tag: payload.asset_tag ?? null,
      asset_name: payload.asset_name,
      manufacturer: payload.manufacturer ?? null,
      model: payload.model ?? null,
      serial_number: payload.serial_number ?? null,
      year_of_make: payload.year_of_make ?? null,
      service: payload.service ?? null,
      status: payload.status ?? "active",
      risk_class: payload.risk_class ?? "medium",
      next_due_date: payload.next_due_date ?? null
    })
    .select("*")
    .single();

  if (error) throw new HttpError(400, error.message, error);

  if (payload.nameplate) {
    await addAssetNameplate(data.id, payload.nameplate);
  }

  return data;
}

export async function getAsset(id: string) {
  const { data: asset, error } = await supabaseService
    .from("assets")
    .select("*")
    .eq("id", id)
    .single();

  if (error) throw new HttpError(404, "Asset not found");

  const { data: nameplate } = await supabaseService
    .from("asset_nameplate")
    .select("*")
    .eq("asset_id", id)
    .single();

  return { ...asset, nameplate };
}

export async function updateAsset(id: string, payload: any) {
  const { data, error } = await supabaseService
    .from("assets")
    .update({
      asset_name: payload.asset_name,
      manufacturer: payload.manufacturer,
      model: payload.model,
      serial_number: payload.serial_number,
      year_of_make: payload.year_of_make,
      service: payload.service,
      status: payload.status,
      risk_class: payload.risk_class,
      next_due_date: payload.next_due_date
    })
    .eq("id", id)
    .select("*")
    .single();

  if (error) throw new HttpError(400, error.message, error);

  if (payload.nameplate) {
    await addAssetNameplate(id, payload.nameplate);
  }

  return data;
}

export async function deleteAsset(id: string) {
  const { error } = await supabaseService.from("assets").delete().eq("id", id);
  if (error) throw new HttpError(400, error.message, error);
}

export async function addAssetNameplate(assetId: string, payload: any) {
  const { error } = await supabaseService
    .from("asset_nameplate")
    .upsert({
      asset_id: assetId,
      design_code: payload.design_code ?? null,
      mawp: payload.mawp ?? null,
      design_pressure: payload.design_pressure ?? null,
      test_pressure: payload.test_pressure ?? null,
      design_temp_min: payload.design_temp_min ?? null,
      design_temp_max: payload.design_temp_max ?? null,
      material: payload.material ?? null,
      corrosion_allowance: payload.corrosion_allowance ?? null,
      capacity: payload.capacity ?? null,
      joint_efficiency: payload.joint_efficiency ?? null,
      relief_valve_pressure: payload.relief_valve_pressure ?? null
    })
    .select("*")
    .single();

  if (error) throw new HttpError(400, error.message, error);
}

