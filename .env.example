# NEVER share these values or commit them!
# Copy to .env.local and fill in your actual values

# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# ⚠️ KEEP PRIVATE - NEVER expose in code
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Application Settings
NODE_ENV=production
NEXT_PUBLIC_APP_URL=https://monroy-qms.example.com

# Security
NEXT_PUBLIC_MAX_REQUESTS_PER_MINUTE=60
JWT_SECRET=your_jwt_secret_here
